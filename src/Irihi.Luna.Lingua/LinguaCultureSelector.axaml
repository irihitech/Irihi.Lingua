<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Irihi.Luna.Lingua.LinguaCultureSelector"
             x:Name="Root">

    <UserControl.Resources>
        <MenuFlyout x:Key="CultureMenuFlyout" />
    </UserControl.Resources>

    <Button x:Name="CultureButton"
            Content="Select culture"
            HorizontalAlignment="Stretch"
            Flyout="{StaticResource CultureMenuFlyout}" />
</UserControl>
