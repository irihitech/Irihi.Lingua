<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Irihi.Luna.Lingua"
             x:Class="Irihi.Luna.Lingua.LinguaCultureSelector"
             x:Name="Root">
    <ComboBox x:Name="CultureComboBox"
              ItemsSource="{Binding Cultures, ElementName=Root}"
              SelectedIndex="{Binding SelectedIndex, ElementName=Root, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="local:LinguaCulture">
                <TextBlock Text="{Binding DisplayText}" />
            </DataTemplate>
        </ComboBox.ItemTemplate>
    </ComboBox>
</UserControl>
