<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Irihi.Lolita.AvaloniaDemo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="480" d:DesignHeight="300"
        x:Class="Irihi.Lolita.AvaloniaDemo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppTitle^}"
        Width="480" Height="300"
        CanResize="False">

    <Design.DataContext>
        <!-- Design-time DataContext for the IDE previewer. -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="20" Margin="40"
                HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- Title label — updates reactively when the culture changes -->
        <TextBlock Text="{Binding AppTitle^}"
                   FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" />

        <!-- Greeting message — also updates reactively -->
        <TextBlock Text="{Binding GreetingMessage^}"
                   FontSize="16"
                   HorizontalAlignment="Center" />

        <!-- Toggle button — its label is itself an observable string,
             demonstrating that even UI chrome can be driven by the same
             IObservable<string> mechanism. -->
        <Button Content="{Binding SwitchLanguageLabel^}"
                Command="{Binding ToggleCultureCommand}"
                HorizontalAlignment="Center"
                Padding="16 8" />

    </StackPanel>
</Window>
