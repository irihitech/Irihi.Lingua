<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Irihi.Lingua.AvaloniaDemo.ViewModels"
        xmlns:local="using:Irihi.Lingua.AvaloniaDemo"
        xmlns:luna="using:Irihi.Luna.Lingua"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="520" d:DesignHeight="480"
        x:Class="Irihi.Lingua.AvaloniaDemo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding AppTitle^}"
        SizeToContent="WidthAndHeight"
        Width="520" Height="480"
        CanResize="True">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <StackPanel Spacing="16" Margin="40"
                HorizontalAlignment="Center" VerticalAlignment="Center">

        <!-- ═══ LinguaCultureSelector (bound) ═══ -->
        <Border BorderBrush="ForestGreen" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="LinguaCultureSelector — Binding" FontSize="14" FontWeight="Bold"
                           Foreground="ForestGreen" />
                <TextBlock Text="Managers &amp; Cultures come from ViewModel."
                           FontSize="11" Foreground="Gray" />

                <luna:LinguaCultureSelector
                    Managers="{Binding Managers}"
                    Cultures="{Binding Cultures}" />

                <TextBlock Text="{Binding CurrentCultureDisplay}"
                           FontSize="12" Foreground="Gray" />
            </StackPanel>
        </Border>

        <!-- ═══ LinguaCultureSelector (inline XAML) ═══ -->
        <Border BorderBrush="Teal" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="LinguaCultureSelector — Inline XAML" FontSize="14" FontWeight="Bold"
                           Foreground="Teal" />
                <TextBlock Text="Cultures defined inline with TypeConverter. Managers still bound (singletons)."
                           FontSize="11" Foreground="Gray" />

                <luna:LinguaCultureSelector
                    Managers="{Binding Managers}">
                    <luna:LinguaCultureSelector.Cultures>
                        <luna:LinguaCulture>en</luna:LinguaCulture>
                        <luna:LinguaCulture DisplayName="简体中文">zh-Hans</luna:LinguaCulture>
                        <luna:LinguaCulture>ja-JP</luna:LinguaCulture>
                    </luna:LinguaCultureSelector.Cultures>
                </luna:LinguaCultureSelector>
            </StackPanel>
        </Border>

        <!-- ═══ RESX section ═══ -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="12">
                <TextBlock Text="RESX Manager" FontSize="14" FontWeight="Bold"
                           Foreground="DodgerBlue" />

                <TextBlock Text="{Binding AppTitle^}"
                           FontSize="18" FontWeight="Bold" />

                <TextBlock Text="{Binding GreetingMessage^}"
                           FontSize="14" />

                <!-- Culture tracking via CultureChanges -->
                <TextBlock Text="{Binding CurrentCultureDisplay}"
                           FontSize="12" Foreground="Gray" />

                <TextBlock Text="{Translate {x:Static local:LanguageManager+Keys.Greeting_Message}}"
                           FontSize="13" FontStyle="Italic"
                           ToolTip.Tip="Bound with TranslateExtension (no ViewModel)" />
            </StackPanel>
        </Border>

        <!-- ═══ JSON section ═══ -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="12">
                <TextBlock Text="JSON Manager" FontSize="14" FontWeight="Bold"
                           Foreground="DarkOrange" />
                <TextBlock Text="(flattened: app.title → app_title)"
                           FontSize="11" Foreground="Gray" />

                <TextBlock Text="{Binding JsonAppTitle^}"
                           FontSize="18" FontWeight="Bold" />

                <TextBlock Text="{Binding JsonGreetingMessage^}"
                           FontSize="14" />

                <TextBlock Text="{Translate {x:Static local:JsonLanguageManager+Keys.app_greeting}}"
                           FontSize="13" FontStyle="Italic"
                           ToolTip.Tip="JSON key bound with TranslateExtension" />
            </StackPanel>
        </Border>

        <!-- ═══ FormatTranslate demo ═══ -->
        <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Padding="12">
            <StackPanel Spacing="8">
                <TextBlock Text="FormatTranslate (RESX)" FontSize="14" FontWeight="Bold"
                           Foreground="DodgerBlue" />
                <NumericUpDown Width="200" Name="page" Value="1" />
                <TextBlock>
                    <TextBlock.Text>
                        <FormatTranslate FormatKey="{x:Static local:LanguageManager+Keys.Page_Template}">
                            <TranslateEntry Binding="{Binding #page.Value}" />
                            <TranslateEntry Key="{x:Static local:LanguageManager+Keys.Greeting_Message}" />
                        </FormatTranslate>
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Toggle button — updates both RESX and JSON managers -->
        <Button Content="{Binding SwitchLanguageLabel^}"
                Command="{Binding ToggleCultureCommand}"
                HorizontalAlignment="Center"
                Padding="16 8" />

    </StackPanel>
</Window>
